# Copy to `.env` and adjust. pydantic-settings reads these (see app/config.py).

# SQLite (default local) or PostgreSQL (e.g. Neon):
# DATABASE_URL=sqlite:///./vaulttracker.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/vaulttracker

# Local dev: use iOS AuthTokenProvider.debugToken as Bearer token
DEBUG_AUTH_ENABLED=true

# Browser CORS (comma-separated). Add your deployed web app origin in production.
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Firebase Admin — path to service account JSON. Required for real JWTs when DEBUG bypass is off.
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Alpha Vantage (stock quotes for /prices and refresh). Optional for local crypto-only testing.
# ALPHA_VANTAGE_API_KEY=
